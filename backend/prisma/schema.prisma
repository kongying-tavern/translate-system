generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique @db.VarChar(50)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  avatarUrl    String?  @map("avatar_url") @db.VarChar(500)
  role         String   @default("super_admin") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  projects       Project[]
  projectMembers ProjectMember[]
  apiKeys        ApiKey[]
  refreshTokens  RefreshToken[]

  @@map("users")
}

model Project {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  name           String   @db.VarChar(255)
  description    String?  @db.Text
  sourceLanguage String   @default("en") @map("source_language") @db.VarChar(35)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  members           ProjectMember[]
  projectLanguages  ProjectLanguage[]
  translationKeys   TranslationKey[]
  layoutTemplates   LayoutTemplate[]
  layoutConfigs     LayoutConfig[]
  exportTemplates   ExportTemplate[]

  @@index([userId])
  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model BaseLanguage {
  languageCode String  @id @map("language_code") @db.VarChar(35)
  englishName  String  @map("english_name") @db.VarChar(255)
  nativeName   String? @map("native_name") @db.VarChar(255)
  iso6391      String? @map("iso_639_1") @db.VarChar(2)
  iso6392      String? @map("iso_639_2") @db.VarChar(3)
  iso6393      String? @map("iso_639_3") @db.VarChar(3)
  region       String? @db.VarChar(100)
  @@map("base_languages")
}

model ProjectLanguage {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  languageCode String   @map("language_code") @db.VarChar(35)
  alias        String?  @db.VarChar(100)
  createdAt    DateTime @default(now()) @map("created_at")
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@unique([projectId, languageCode])
  @@map("project_languages")
}

model TranslationKey {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  key          String   @db.VarChar(500)
  sourceText   String   @map("source_text") @db.Text
  context      String?  @db.Text
  tags         String[] @default([])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  project Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  values  TranslationValue[]

  @@unique([projectId, key])
  @@index([key])
  @@map("translation_keys")
}

model TranslationValue {
  id              String   @id @default(uuid()) @db.Uuid
  keyId           String   @map("key_id") @db.Uuid
  languageCode    String   @map("language_code") @db.VarChar(35)
  translatedText  String   @default("") @map("translated_text") @db.Text
  isReviewed      Boolean  @default(false) @map("is_reviewed")
  reviewerComment String?  @map("reviewer_comment") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  key TranslationKey @relation(fields: [keyId], references: [id], onDelete: Cascade)

  @@unique([keyId, languageCode])
  @@map("translation_values")
}

model LayoutTemplate {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  name         String   @db.VarChar(255)
  description  String?  @db.Text
  thumbnailUrl String?  @map("thumbnail_url") @db.VarChar(500)
  config       Json     @default("{}") @db.JsonB
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  layoutConfigs LayoutConfig[]
  @@index([projectId])
  @@map("layout_templates")
}

model LayoutConfig {
  id             String   @id @default(uuid()) @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  name           String   @db.VarChar(255)
  templateId     String?  @map("template_id") @db.Uuid
  overrideConfig Json     @default("{}") @map("override_config") @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  project  Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template LayoutTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  @@index([projectId])
  @@index([templateId])
  @@map("layout_configs")
}

model ExportTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  name        String   @db.VarChar(255)
  description String?  @db.Text
  formatType  String   @default("custom") @map("format_type") @db.VarChar(50)
  config      Json     @default("{}") @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@index([projectId])
  @@map("export_templates")
}

model ApiKey {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String   @db.VarChar(100)
  apiKey    String   @unique @map("api_key") @db.VarChar(64)
  secret    String   @db.VarChar(255)
  enabled   Boolean  @default(true)
  lastUsed  DateTime? @map("last_used")
  createdAt DateTime @default(now()) @map("created_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([apiKey])
  @@map("api_keys")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}
